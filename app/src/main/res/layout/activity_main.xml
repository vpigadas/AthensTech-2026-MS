<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="TITLE"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <Button
        android:id="@+id/main_btn_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RecyclerView Screen"/>

    <Button
        android:id="@+id/main_btn_sample"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sample Screen"/>

    <Button
        android:id="@+id/main_btn_network"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Network Screen"/>

    <Button
        android:id="@+id/main_btn_close"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CLOSE"/>

</LinearLayout>